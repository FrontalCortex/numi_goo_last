rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcılar: giriş yapmış kullanıcı sadece kendi dokümanını okuyup yazabilir
    // Email kontrolü için: unauthenticated kullanıcılar users collection'ında where query yapabilir (list izni)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Email kontrolü için: unauthenticated kullanıcılar where query yapabilir
      allow read: if request.auth == null;
    }

    // Öğretmen davet kodları: giriş yapmış kullanıcı okuyabilir; kayıt sırasında update (used) için yazma
    match /teacherInvites/{code} {
      allow read, write: if request.auth != null;
    }

    // Öğrenci doğrulama kodları: unauthenticated kullanıcılar OTP doğrulama için okuyup update edebilir
    match /studentVerificationCodes/{code} {
      allow read, write: if true; // OTP doğrulama için herkes okuyup yazabilir
    }

    // Bekleyen kayıtlar (e-posta doğrulama): unauthenticated kullanıcılar kayıt için okuyup yazabilir
    match /pendingRegistrations/{docId} {
      allow read, write: if true; // Kayıt akışı için herkes okuyup yazabilir
    }

    // OTP rate limit ve yanlış deneme sayacı: sadece Cloud Functions (Admin SDK) yazar, istemci erişemez
    match /otpRateLimits/{docId} {
      allow read, write: if false;
    }
    match /otpWrongAttempts/{docId} {
      allow read, write: if false;
    }

    // Öğrenci soruları: öğrenci kendi sorularını okur; öğretmen pending veya kendi sahiplendiğini okur
    match /questions/{questionId} {
      allow read: if request.auth != null && (
        resource.data.studentUid == request.auth.uid ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TEACHER' && (resource.data.status == 'pending' || resource.data.claimedByTeacherUid == request.auth.uid))
      );
      allow create: if request.auth != null && request.resource.data.studentUid == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.studentUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TEACHER'
      );
      allow delete: if false;
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/questions/$(questionId)).data.studentUid == request.auth.uid ||
          get(/databases/$(database)/documents/questions/$(questionId)).data.claimedByTeacherUid == request.auth.uid
        );
      }
    }

    // Yukarıdakilerin dışındaki tüm path'ler reddedilir
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
