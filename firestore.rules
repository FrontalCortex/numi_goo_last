rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcılar: giriş yapmış kullanıcı sadece kendi dokümanını okuyup yazabilir (fcmToken, fcmTokenUpdatedAt dahil)
    // Email kontrolü için: unauthenticated kullanıcılar users collection'ında where query yapabilir (list izni)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Email kontrolü için: unauthenticated kullanıcılar where query yapabilir
      allow read: if request.auth == null;
    }

    // Kullanıcının kendi alt koleksiyonları (lessonProgress, missionProgress, dailyQuestion vb.)
    // sadece ilgili kullanıcı tarafından okunup yazılabilir.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Öğretmen davet kodları: giriş yapmış kullanıcı okuyabilir; kayıt sırasında update (used) için yazma
    match /teacherInvites/{code} {
      allow read, write: if request.auth != null;
    }

    // Öğrenci doğrulama kodları: unauthenticated kullanıcılar OTP doğrulama için okuyup update edebilir
    match /studentVerificationCodes/{code} {
      allow read, write: if true; // OTP doğrulama için herkes okuyup yazabilir
    }

    // Bekleyen kayıtlar (e-posta doğrulama): unauthenticated kullanıcılar kayıt için okuyup yazabilir
    match /pendingRegistrations/{docId} {
      allow read, write: if true; // Kayıt akışı için herkes okuyup yazabilir
    }

    // OTP rate limit ve yanlış deneme sayacı: sadece Cloud Functions (Admin SDK) yazar, istemci erişemez
    match /otpRateLimits/{docId} {
      allow read, write: if false;
    }
    match /otpWrongAttempts/{docId} {
      allow read, write: if false;
    }

    // Sorular: giriş yapmış kullanıcı okuyup yazabilir (deletedForUids arrayUnion dahil). Kalıcı silme sadece soru sahibi (öğrenci).
    match /questions/{questionId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.studentUid == request.auth.uid;
    }
    match /questions/{questionId}/messages/{messageId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // Bildirilen mesajlar: giriş yapmış kullanıcı rapor ekleyebilir; kendi raporunu veya öğretmen tümünü okuyabilir
    match /messageReports/{reportId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.reportedByUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TEACHER'
      );
      allow update, delete: if false;
    }

    // Tahta üst dokümanı (meta): sezon sonu CF sorgusu için partId / lessonIndex / season (+ isteğe bağlı titleUnit).
    // Not: [FieldValue.serverTimestamp] yazımında kurallar `updatedAt is timestamp` ile doğrulanamaz; yalnızca alanın varlığını şart koşuyoruz.
    match /lessonLeaderboards/{leaderboardId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.partId is number
        && request.resource.data.lessonIndex is number
        && request.resource.data.season is number
        && ('updatedAt' in request.resource.data)
        && (!('titleUnit' in request.resource.data)
            || (request.resource.data.titleUnit is string
                && request.resource.data.titleUnit.size() < 200));
      allow delete: if false;
    }

    // Ders liderlik tablosu: giriş yapmış herkes okur; her kullanıcı yalnızca kendi entry dokümanını yazar.
    // İstemci [LessonLeaderboardRepository]: recordScore (puan), recordLabel, displayName, updatedAt, photoUrl.
    // Tahta doküman id: `part_{partId}_lesson_{i}_season_{n}` (sezon başına ayrı tahta). Kurallar burada
    // {leaderboardId} ile herhangi bir string id'ye izin verir; ayrıca id kalıbını kısıtlamak isterseniz
    // `leaderboardId.matches('part_.*_lesson_.*_season_.*')` gibi bir koşul eklenebilir.
    match /lessonLeaderboards/{leaderboardId}/entries/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && ('recordScore' in request.resource.data)
        && request.resource.data.recordScore is number
        && request.resource.data.recordScore >= 1
        && request.resource.data.recordScore <= 2000000000
        && ('recordLabel' in request.resource.data)
        && request.resource.data.recordLabel is string
        && request.resource.data.recordLabel.size() < 128
        && ('displayName' in request.resource.data)
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() < 128
        && ('updatedAt' in request.resource.data)
        && request.resource.data.updatedAt is timestamp
        && (!('photoUrl' in request.resource.data)
            || (request.resource.data.photoUrl is string
                && request.resource.data.photoUrl.size() < 512))
        && (!('titleUnit' in request.resource.data)
            || (request.resource.data.titleUnit is string
                && request.resource.data.titleUnit.size() < 200));
      allow delete: if false;
    }

    // Yukarıdakilerin dışındaki tüm path'ler reddedilir (ileride meetingRequests vb. eklenebilir)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
