<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/bottomSheetLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_background"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:padding="@dimen/lesson_sheet_container_padding"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/lesson_sheet_top_row_height"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- SOL YARI -->
            <TextView
                android:id="@+id/lessonTitle"
                android:layout_width="wrap_content"
                android:maxLines="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/lesson_sheet_content_start_margin"
                android:textSize="@dimen/lesson_sheet_title_size"
                android:textStyle="bold"
                android:textColor="@color/lesson_completed"
                android:paddingTop="@dimen/lesson_sheet_title_padding_top"
                android:layout_marginBottom="@dimen/lesson_sheet_title_margin_bottom"/>

            <!-- SAĞ YARI -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/lesson_sheet_title_record_gap"
                android:elevation="20dp"
                android:clipChildren="true"
                android:clipToPadding="true">
                <LinearLayout
                    android:id="@+id/recordLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="@dimen/lesson_sheet_content_end_margin"
                    android:gravity="center_vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/fireAnimID"
                    android:layout_width="@dimen/lesson_sheet_lottie_size"
                    android:layout_height="@dimen/lesson_sheet_lottie_size"
                    android:layout_marginEnd="@dimen/lesson_sheet_lottie_margin_end"
                    android:visibility="gone"
                    tools:visibility="gone"
                    app:lottie_fileName="fire_anim.json"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    android:paddingBottom="@dimen/lesson_sheet_lottie_padding_bottom"/>

                <TextView
                    android:id="@+id/recordText"
                    android:layout_width="wrap_content"
                    android:maxLines="1"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/lesson_sheet_record_size"
                    android:textColor="@color/background_color"
                    android:paddingEnd="@dimen/lesson_sheet_record_end_padding"
                    android:gravity="center_vertical"/>

                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <!-- lessonDescription ve againTutorial yan yana -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/lesson_sheet_middle_row_margin_bottom">
            
            <TextView
                android:id="@+id/lessonDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/lesson_sheet_content_start_margin"
                android:textSize="@dimen/lesson_sheet_body_size"
                android:textColor="@color/lesson_completed"/>
            
            <TextView
                android:id="@+id/againTutorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/lesson_sheet_content_end_margin"
                android:gravity="center"
                android:visibility="invisible"
                android:paddingHorizontal="@dimen/lesson_sheet_again_padding_h"
                android:paddingVertical="@dimen/lesson_sheet_again_padding_v"
                android:text="Eğitimi tekrarla"
                android:background="@drawable/skip_tutorial"
                android:backgroundTint="@color/lesson_completed"
                android:textAlignment="center"
                android:textColor="@color/background_color"
                android:textSize="@dimen/lesson_sheet_again_size"/>
        </LinearLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/actionButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/lesson_sheet_content_start_margin"
                android:layout_marginEnd="@dimen/lesson_sheet_content_end_margin"
                android:padding="@dimen/lesson_sheet_button_padding"
                android:layout_weight="1"
                android:backgroundTint="@color/lesson_completed"
                android:textAllCaps="true"
                android:text="Gözden geçir"
                android:textColor="@color/background_color"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="@dimen/lesson_sheet_button_text_size"/>
            <Button
                android:id="@+id/tutorialActionButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/lesson_sheet_content_end_margin"
                android:padding="@dimen/lesson_sheet_button_padding"
                android:backgroundTint="@color/white"
                android:textAllCaps="true"
                android:text="Öğretici"
                android:visibility="gone"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="@dimen/lesson_sheet_button_text_size"/>
        </LinearLayout>


    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>