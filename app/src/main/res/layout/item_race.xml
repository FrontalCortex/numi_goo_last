<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/map_lesson_item_padding">

    <androidx.cardview.widget.CardView
        android:id="@+id/lessonCard"
        android:layout_width="@dimen/map_lesson_card_size"
        android:layout_height="@dimen/map_lesson_card_size"
        android:layout_gravity="center"
        app:cardCornerRadius="@dimen/map_lesson_card_corner_radius"
        android:foreground="?attr/selectableItemBackground"
        android:stateListAnimator="@animator/lesson_state_animator"
        >

        <com.example.app.CircleProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:progress="0"
            app:progressBarThickness="6dp"
            app:progressbarColor="@color/circleForeground_color"
            app:backgroundBarColor="@color/circleBackground_color">
        </com.example.app.CircleProgressBar>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/map_lesson_card_inner_padding">

            <ImageView
                android:id="@+id/lessonIcon"
                android:layout_width="@dimen/map_race_icon_size"
                android:layout_height="@dimen/map_race_icon_size"
                android:layout_centerInParent="true"
                android:src="@drawable/flag_ic"
                />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>