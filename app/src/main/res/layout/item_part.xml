<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >

    <View
        android:id="@+id/cizgiIsteBra"
        android:layout_width="match_parent"
        android:layout_height="@dimen/map_part_divider_height"
        android:background="@color/lesson_locked"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:id="@+id/cizgiIsteBra2"
        android:layout_width="match_parent"
        android:layout_height="@dimen/map_part_divider_height"
        android:background="@color/lesson_locked"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/partLocked_color"
        android:padding="@dimen/map_part_padding"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@id/cizgiIsteBra"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cizgiIsteBra2">

    <!-- Kilitli başlık -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/map_part_button_margin_bottom">

        <ImageView
            android:layout_width="@dimen/map_part_lock_icon_size"
            android:layout_height="@dimen/map_part_lock_icon_size"
            android:src="@drawable/lock_ic"
            android:tint="#B0B0B0"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/sectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. Kısım"
            android:textColor="#B0B0B0"
            android:textStyle="bold"
            android:textSize="@dimen/map_part_section_title_size"/>
    </LinearLayout>

    <!-- Açıklama -->
    <TextView
        android:id="@+id/sectionDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Basit konuşmalar için kelime, ifade ve dil bilgisi konseptlerini öğren"
        android:textColor="#A0A0A0"
        android:textSize="@dimen/map_part_description_size"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/map_part_desc_margin_bottom"/>

    <!-- "İLERİ SAR!" butonu -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/fastForwardButton"
        android:layout_width="match_parent"
        android:layout_height="@dimen/map_part_button_height"
        android:text="İLERİ SAR!"
        android:textSize="@dimen/map_part_button_text_size"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:textColor="#7FB3D5"
        app:cornerRadius="@dimen/map_part_button_corner_radius"
        app:strokeColor="#5B5D5F"
        app:strokeWidth="@dimen/map_part_button_stroke_width"
        android:backgroundTint="#152121"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_marginTop="@dimen/map_part_button_margin_top"
        android:layout_marginBottom="@dimen/map_part_button_margin_bottom"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
