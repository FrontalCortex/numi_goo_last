<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/notificationTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sorular"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

        <LinearLayout
            android:id="@+id/teacherTabContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:gravity="start">

            <TextView
                android:id="@+id/tabPool"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:text="Soru havuzu"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/hint_background"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tabChats"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:text="Sohbetler"
                android:textSize="16sp"
                android:textColor="#AAAAAA" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/studentTabContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:gravity="start"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tabBekleyen"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:text="Bekleyen"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/hint_background"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tabCozulen"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:text="Çözülen"
                android:textSize="16sp"
                android:textColor="#AAAAAA" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/questionsRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_question" />

    <!-- Sohbet açılmadan önce mesajlar preload edilirken gösterilen loading -->
    <ProgressBar
        android:id="@+id/chatLoading"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/emptyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Henüz soru yok"
        android:textColor="#888888"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Öğretmen hesabı onay beklerken: sadece bu blok gösterilir -->
    <LinearLayout
        android:id="@+id/teacherApprovalPendingContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/teacherApprovalPendingMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mesajlaşma özelliğini kullanabilmek için öğretmen hesabınızın onaylanması gerekmektedir."
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <Button
            android:id="@+id/teacherApprovalSupportButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Destek ile İletişime Geç"
            android:textColor="@android:color/white"
            android:background="@drawable/hint_background" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
