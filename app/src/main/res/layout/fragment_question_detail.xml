<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <ProgressBar
        android:id="@+id/contentLoadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back_arrow"
        android:contentDescription="Geri"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/lesson_completed" />

    <ScrollView
        android:id="@+id/contentScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/backButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/claimButton">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/screenshot_border_bg">

                <ImageView
                    android:id="@+id/screenshotImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:contentDescription="Ekran görüntüsü" />

                <FrameLayout
                    android:id="@+id/videoContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="200dp"
                    android:visibility="gone"
                    android:background="#22000000">

                    <androidx.media3.ui.PlayerView
                        android:id="@+id/questionDetailVideoPlayer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="200dp"
                        app:show_buffering="when_playing"
                        app:use_controller="true" />

                    <ImageView
                        android:id="@+id/videoPlayOverlay"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_media_play"
                        android:background="@drawable/screenshot_border_bg"
                        android:padding="12dp"
                        android:contentDescription="Oynat"
                        app:tint="@android:color/white" />

                    <ImageButton
                        android:id="@+id/videoFullscreenButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_fullscreen"
                        android:contentDescription="Tam ekran"
                        app:tint="@android:color/white" />
                </FrameLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/messageLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Öğrenci mesajı"
                android:textSize="14sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/messageText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:background="#4E4E4E"
                android:textColor="@android:color/white"
                android:padding="12dp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/claimButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Sahiplen"
        android:textAllCaps="false"
        android:visibility="gone"
        android:backgroundTint="@color/lesson_completed"
        android:textColor="@android:color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />
</androidx.constraintlayout.widget.ConstraintLayout>


