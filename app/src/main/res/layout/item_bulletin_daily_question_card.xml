<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools"

    android:id="@+id/dailyQuestionCard"

    android:layout_width="match_parent"

    android:layout_height="wrap_content"

    android:layout_marginTop="10dp"

    android:layout_marginBottom="10dp"

    app:cardBackgroundColor="@android:color/transparent"

    app:cardCornerRadius="18dp"

    app:cardElevation="2dp"

    android:clipChildren="false"

    android:clipToPadding="false"

    app:strokeWidth="0dp">



    <androidx.constraintlayout.widget.ConstraintLayout

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:background="@drawable/bg_daily_question_card"

        android:clipChildren="false"

        android:clipToPadding="false"

        android:padding="16dp">



        <LinearLayout

            android:id="@+id/dailyQuestionCardTitleRow"

            android:layout_width="0dp"

            android:layout_height="wrap_content"

            android:gravity="center_vertical"

            android:orientation="horizontal"

            app:layout_constraintEnd_toStartOf="@id/dailyQuestionBrokenHeart"

            app:layout_constraintStart_toStartOf="parent"

            app:layout_constraintTop_toTopOf="parent">

            <ImageView

                android:id="@+id/dailyQuestionCardTitleIcon"

                android:layout_width="28dp"

                android:layout_height="28dp"

                android:contentDescription="@null"

                android:scaleType="fitCenter"

                android:src="@drawable/target_ic" />

            <TextView

                android:id="@+id/dailyQuestionCardTitle"

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:layout_marginStart="6dp"

                android:includeFontPadding="false"

                android:text="@string/daily_question_card_title"

                android:textColor="@android:color/white"

                android:textSize="18sp"

                android:textStyle="bold" />

        </LinearLayout>



        <com.airbnb.lottie.LottieAnimationView

            android:id="@+id/dailyQuestionBrokenHeart"

            android:layout_width="28dp"

            android:layout_height="28dp"

            android:layout_marginEnd="6dp"

            android:contentDescription="@null"

            app:layout_constraintBottom_toBottomOf="@id/dailyQuestionCardChevron"

            app:layout_constraintEnd_toStartOf="@id/dailyQuestionCardChevron"

            app:layout_constraintTop_toTopOf="@id/dailyQuestionCardChevron"

            app:lottie_autoPlay="false"

            app:lottie_fileName="broken_heart_anim.json"

            app:lottie_loop="false" />



        <ImageView

            android:id="@+id/dailyQuestionCardChevron"

            android:layout_width="16dp"

            android:layout_height="16dp"

            android:contentDescription="@string/daily_question_card_open"

            android:src="@drawable/dualingo_arrow_ic"

            app:layout_constraintBottom_toBottomOf="parent"

            app:layout_constraintEnd_toEndOf="parent"

            app:layout_constraintTop_toTopOf="parent"

            app:tint="@android:color/white" />



        <TextView

            android:id="@+id/dailyQuestionUnitSubtitle"

            android:layout_width="0dp"

            android:layout_height="wrap_content"

            android:layout_marginTop="8dp"

            android:ellipsize="end"

            android:maxLines="1"

            android:textColor="#FFF3E0"

            android:textSize="14sp"

            app:layout_constraintEnd_toEndOf="parent"

            app:layout_constraintStart_toStartOf="parent"

            app:layout_constraintTop_toBottomOf="@id/dailyQuestionCardTitleRow" />



        <FrameLayout

            android:id="@+id/dailyQuestionProgressZone"

            android:layout_width="@dimen/daily_question_progress_width"

            android:layout_height="@dimen/daily_question_progress_height"

            android:layout_marginTop="12dp"

            android:clickable="false"

            android:clipChildren="false"

            android:clipToPadding="false"

            android:focusable="false"

            app:layout_constraintStart_toStartOf="parent"

            app:layout_constraintTop_toBottomOf="@id/dailyQuestionUnitSubtitle">



            <View

                android:id="@+id/dailyQuestionProgressTrack"

                android:layout_width="match_parent"

                android:layout_height="match_parent"

                android:background="@drawable/daily_question_progress_track"

                android:contentDescription="@null" />



            <View

                android:id="@+id/dailyQuestionProgressFill"

                android:layout_width="0dp"

                android:layout_height="match_parent"

                android:layout_gravity="start|center_vertical"

                android:contentDescription="@null" />



            <View

                android:id="@+id/dailyQuestionProgressShine"

                android:layout_width="0dp"

                android:layout_height="@dimen/mission_progress_shine_height"

                android:layout_gravity="top|start"

                android:layout_marginStart="@dimen/mission_progress_shine_inset_start"

                android:layout_marginTop="@dimen/mission_progress_shine_top"

                android:contentDescription="@null" />



            <TextView


                android:id="@+id/dailyQuestionProgressText"

                android:layout_width="match_parent"

                android:layout_height="match_parent"

                android:elevation="2dp"

                android:gravity="center"

                android:outlineProvider="none"

                android:paddingEnd="14dp"

                android:textColor="@android:color/white"

                android:textSize="14sp"

                android:textStyle="bold"

                tools:text="2/3" />

        </FrameLayout>



        <ImageView

            android:id="@+id/dailyQuestionProgressCrystal"

            android:layout_width="@dimen/daily_question_progress_crystal_size"

            android:layout_height="@dimen/daily_question_progress_crystal_size"

            android:layout_marginEnd="-6dp"

            android:contentDescription="@null"

            android:elevation="6dp"

            android:layout_marginBottom="4dp"

            android:scaleType="fitCenter"

            android:src="@drawable/crystal_ic"

            app:layout_constraintBottom_toBottomOf="@id/dailyQuestionProgressZone"

            app:layout_constraintEnd_toEndOf="@id/dailyQuestionProgressZone"

            app:layout_constraintTop_toTopOf="@id/dailyQuestionProgressZone" />



        <TextView

            android:id="@+id/dailyQuestionFocusLabel"

            android:layout_width="0dp"

            android:layout_height="wrap_content"

            android:layout_marginTop="10dp"

            android:layout_marginEnd="8dp"

            android:textColor="#FFECB3"

            android:textSize="13sp"

            app:layout_constraintBottom_toBottomOf="parent"

            app:layout_constraintEnd_toStartOf="@id/dailyQuestionRenewCountdown"

            app:layout_constraintStart_toStartOf="parent"

            app:layout_constraintTop_toBottomOf="@id/dailyQuestionProgressZone"

            app:layout_constraintVertical_bias="1.0" />



        <TextView

            android:id="@+id/dailyQuestionRenewCountdown"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="10dp"

            android:textColor="#FFECB3"

            android:textSize="12sp"

            app:layout_constraintBottom_toBottomOf="parent"

            app:layout_constraintEnd_toEndOf="parent"

            app:layout_constraintTop_toBottomOf="@id/dailyQuestionProgressZone"

            app:layout_constraintVertical_bias="1.0"

            tools:text="04:32" />



    </androidx.constraintlayout.widget.ConstraintLayout>



</com.google.android.material.card.MaterialCardView>

