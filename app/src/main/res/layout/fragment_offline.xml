<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/dark_background">

    <ImageView
        android:id="@+id/offlineIcon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/no_wifi_ic"
        android:contentDescription="@string/offline_title" />

    <TextView
        android:id="@+id/offlineTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/offline_title"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/offlineMessageText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/offline_message"
        android:textSize="14sp" />

    <Button
        android:id="@+id/offlineRetryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/offline_retry" />

</LinearLayout>

