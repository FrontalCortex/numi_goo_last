<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/currencyPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/message_topbar"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/teacherSendBackButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back_arrow"
            android:contentDescription="@string/notification_download_cancel"
            android:tint="@android:color/white"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/diamondID"
            android:src="@drawable/diamond"
            android:layout_width="40dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:contentDescription="Coin" />

        <TextView
            android:id="@+id/currencyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFD600"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginStart="8dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <ImageView
            android:id="@+id/energyIcon"
            android:src="@drawable/energy_ic"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:contentDescription="Energy" />

        <TextView
            android:id="@+id/energyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5/5"
            android:textColor="#FFD600"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginStart="8dp"/>


    </LinearLayout>

    <!-- Abacus Fragment Container -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/abacusFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="10dp"/>
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/resultFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="10dp"/>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/currencyPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationID">


        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragmentContainerID"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Karartma için arka plan view'ı -->
        <View
            android:id="@+id/scrimView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000"
            android:alpha="0"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/circleBackground_color"
        app:layout_constraintBottom_toTopOf="@id/teacherSendToQuestionBar"/>

    <!-- Öğretmen için: seçilen soruya gönder barı -->
    <LinearLayout
        android:id="@+id/teacherSendToQuestionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/message_topbar"
        android:elevation="22dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationID">

        <TextView
            android:id="@+id/teacherSendQuestionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="" />

        <ImageButton
            android:id="@+id/teacherSendButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/send_ic"
            android:contentDescription="@string/send"
            android:tint="@android:color/white" />

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationID"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/coordinator_layout"
        app:menu="@menu/bottom_menu"
        app:itemIconSize="32dp"
        app:itemIconTint="@null"
        app:itemTextColor="@null"
        android:background="@color/message_topbar"
        app:labelVisibilityMode="labeled"/>

    <!-- Ekran kaydı sırasında süre göstergesi -->
    <FrameLayout
        android:id="@+id/recordingOverlayContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:elevation="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Race panel açıkken alt bar tıklanmasın; bu overlay tıklamaları yer -->
    <View
        android:id="@+id/bottomPanelOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:background="@android:color/transparent"
        android:elevation="16dp"
        app:layout_constraintTop_toTopOf="@id/bottomNavigationID"
        app:layout_constraintBottom_toBottomOf="@id/bottomNavigationID"
        app:layout_constraintStart_toStartOf="@id/bottomNavigationID"
        app:layout_constraintEnd_toEndOf="@id/bottomNavigationID"/>

    <!-- CreateQuestionFragment her zaman en üstte; soru ekranı/video bu container'da açılır -->
    <FrameLayout
        android:id="@+id/createQuestionOverlayContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:elevation="25dp"
        android:background="#00FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>