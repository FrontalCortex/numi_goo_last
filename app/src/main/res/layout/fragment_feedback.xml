<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Üst Görsel / İkon -->
            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/hint_background">
                <ImageView
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:layout_gravity="center"
                    android:src="@drawable/feedback_ic"/>
            </FrameLayout>

            <!-- Başlık -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bize Ulaşın"
                android:gravity="center"
                android:textColor="@color/dark_text"
                android:textSize="22sp"
                android:fontFamily="@font/font_regular"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bir sorun mu yaşadınız veya harika bir öneriniz mi var? Uygulamayı daha iyi hale getirmemize yardımcı olun."
                android:gravity="center"
                android:textColor="@color/dark_text_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/font_regular"
                android:layout_marginBottom="32dp" />

            <!-- Text Input -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mesajınız"
                android:textColor="@color/dark_text"
                android:textSize="15sp"
                android:fontFamily="@font/font_regular"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/feedbackInput"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:hint="Buraya yazabilirsiniz..."
                android:textSize="14sp"
                android:padding="16dp"
                android:background="@drawable/hint_background"
                android:textColor="@color/dark_text"
                android:textColorHint="#80FFFFFF"
                android:fontFamily="@font/font_regular"
                android:layout_marginBottom="32dp" />

            <!-- Boşluk -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Butonlar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/closeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="İptal"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="@color/dark_text_secondary"
                    android:backgroundTint="@android:color/transparent"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/font_regular" />

                <Button
                    android:id="@+id/sendFeedbackButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Gönder"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="@color/button_text_enabled"
                    android:backgroundTint="@color/lesson_completed"
                    android:paddingHorizontal="32dp"
                    android:fontFamily="@font/font_regular"
                    android:enabled="false" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Gönderim sırasında tüm ekranı kilitleyen overlay -->
    <FrameLayout
        android:id="@+id/sendBlockingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:elevation="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/sendProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@android:color/white" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
