<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="@dimen/create_question_screen_padding"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/create_question_min_height">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="@dimen/create_question_nav_icon_size"
                android:layout_height="@dimen/create_question_nav_icon_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back_arrow"
                app:tint="@color/message_buttons"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="@dimen/create_question_nav_margin_top" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sorunu gönder"
                android:textSize="@dimen/create_question_title_text_size"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="@dimen/create_question_title_margin_top" />

            <FrameLayout
                android:id="@+id/mediaContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/create_question_media_min_height"
                android:background="@drawable/screenshot_border_bg"
                app:layout_constraintTop_toBottomOf="@id/titleText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/create_question_section_margin_top">

                <ImageView
                    android:id="@+id/screenshotImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:scaleType="centerInside"
                    android:contentDescription="Ekran görüntüsü" />

                <androidx.media3.ui.PlayerView
                    android:id="@+id/videoPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/create_question_video_min_height"
                    android:visibility="gone"
                    app:show_buffering="when_playing" />

                <ImageButton
                    android:id="@+id/videoFullscreenButton"
                    android:layout_width="@dimen/create_question_media_action_size"
                    android:layout_height="@dimen/create_question_media_action_size"
                    android:layout_gravity="top|end"
                    android:layout_margin="@dimen/create_question_media_action_margin"
                    android:visibility="gone"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_fullscreen"
                    android:contentDescription="Tam ekran"
                    app:tint="@android:color/white" />

                <ImageButton
                    android:id="@+id/screenshotAnnotateButton"
                    android:layout_width="@dimen/create_question_media_action_size"
                    android:layout_height="@dimen/create_question_media_action_size"
                    android:layout_gravity="top|end"
                    android:layout_margin="@dimen/create_question_media_action_margin"
                    android:visibility="gone"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/question_pencil_ic"
                    android:contentDescription="Çizim yap"
                    app:tint="@android:color/white" />
            </FrameLayout>

            <TextView
                android:id="@+id/headerLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sorunuza başlık giriniz"
                android:textSize="@dimen/create_question_label_text_size"
                android:textColor="@android:color/white"
                android:layout_marginTop="@dimen/create_question_section_margin_top"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/mediaContainer" />
            <EditText
                android:id="@+id/headerInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minLines="1"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:hint="5'lik kural mantığı"
                android:textSize="@dimen/create_question_input_text_size"
                android:padding="@dimen/create_question_input_padding"
                android:background="@drawable/hint_background"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF"
                android:layout_marginTop="@dimen/create_question_field_spacing"
                app:layout_constraintTop_toBottomOf="@id/headerLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
            <TextView
                android:id="@+id/descriptionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sorunuzu kısaca açıklayın"
                android:textSize="@dimen/create_question_label_text_size"
                android:textColor="@android:color/white"
                android:layout_marginTop="@dimen/create_question_section_margin_top"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerInput" />

            <EditText
                android:id="@+id/descriptionInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minLines="4"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:hint="Örnek: Bu sayfadaki şu soruyu anlamadım..."
                android:textSize="@dimen/create_question_input_text_size"
                android:padding="@dimen/create_question_input_padding"
                android:background="@drawable/hint_background"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF"
                android:layout_marginTop="@dimen/create_question_field_spacing"
                app:layout_constraintTop_toBottomOf="@id/descriptionLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <FrameLayout
                android:id="@+id/sendButtonContainer"
                android:layout_width="0dp"
                android:layout_height="@dimen/create_question_send_button_height"
                android:layout_marginTop="@dimen/create_question_send_button_margin_v"
                android:layout_marginBottom="@dimen/create_question_send_button_margin_v"
                app:layout_constraintTop_toBottomOf="@id/descriptionInput"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <Button
                    android:id="@+id/sendButton"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Gönder"
                    android:textAllCaps="false"
                    android:textSize="@dimen/create_question_send_text_size"
                    android:backgroundTint="@color/lesson_completed"
                    android:textColor="@android:color/black" />

            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/sendBlockingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:elevation="@dimen/create_question_overlay_elevation"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/sendProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@android:color/white" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

