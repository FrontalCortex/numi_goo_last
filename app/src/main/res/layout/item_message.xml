<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/item_message_outer_padding"
    android:paddingEnd="@dimen/item_message_outer_padding"
    android:paddingTop="@dimen/item_message_outer_padding"
    android:paddingBottom="@dimen/item_message_outer_padding">

    <LinearLayout
        android:id="@+id/messageContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:maxWidth="@dimen/chat_bubble_max_width"
        android:gravity="start">

        <LinearLayout
            android:id="@+id/bubbleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:paddingStart="@dimen/item_message_bubble_padding"
            android:paddingEnd="@dimen/item_message_bubble_padding"
            android:paddingTop="@dimen/item_message_bubble_padding"
            android:paddingBottom="@dimen/item_message_bubble_padding"
            android:background="@drawable/hint_background"
            tools:background="@drawable/chat_bubble_me">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical|end">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/chat_bubble_max_width">

                <TextView
                    android:id="@+id/messageText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="@dimen/chat_bubble_max_width"
                    android:textSize="@dimen/item_message_text_size"
                    android:textColor="@android:color/white"
                    tools:text="Örnek mesaj" />

                <LinearLayout
                    android:id="@+id/audioRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:minWidth="@dimen/item_message_audio_row_min_width"
                    android:paddingVertical="@dimen/item_message_audio_row_padding_v"
                    android:paddingEnd="@dimen/item_message_audio_row_padding_end"
                    tools:visibility="visible">
                    <ImageView
                        android:id="@+id/audioPlayIcon"
                        android:layout_width="@dimen/item_message_audio_play_size"
                        android:layout_height="@dimen/item_message_audio_play_size"
                        android:src="@drawable/ic_play_circle"
                        android:contentDescription="@null" />
                    <TextView
                        android:id="@+id/audioLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/item_message_inline_gap"
                        android:textSize="@dimen/item_message_secondary_text_size"
                        android:textColor="@android:color/white"
                        android:text="Ses kaydı" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/videoRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    tools:visibility="visible">
                    <ImageView
                        android:id="@+id/videoThumb"
                        android:layout_width="@dimen/chat_media_max_width"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:minHeight="@dimen/chat_media_min_height"
                        android:maxWidth="@dimen/chat_media_max_width"
                        android:scaleType="centerCrop"
                        android:clipToOutline="true"
                        android:background="@drawable/chat_media_video_bg"
                        android:contentDescription="@null" />
                    <ImageView
                        android:id="@+id/videoPlayIcon"
                        android:layout_width="@dimen/item_message_play_overlay_size"
                        android:layout_height="@dimen/item_message_play_overlay_size"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_circle"
                        android:contentDescription="@null" />

                    <LinearLayout
                        android:id="@+id/videoMetaContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="@dimen/item_message_meta_margin"
                        android:layout_marginBottom="@dimen/item_message_meta_margin"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/item_message_meta_padding_h"
                        android:paddingEnd="@dimen/item_message_meta_padding_h"
                        android:paddingTop="@dimen/item_message_meta_padding_v"
                        android:paddingBottom="@dimen/item_message_meta_padding_v"
                        android:background="#80000000"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/videoTimeView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/item_message_meta_text_size"
                            android:textColor="#CCFFFFFF"
                            tools:text="14:20" />

                        <ImageView
                            android:id="@+id/videoTickView"
                            android:layout_width="@dimen/item_message_tick_size"
                            android:layout_height="@dimen/item_message_tick_size"
                            android:layout_marginStart="@dimen/item_message_tick_gap"
                            android:scaleType="fitCenter"
                            android:visibility="gone"
                            android:contentDescription="@null"
                            tools:visibility="visible" />
                    </LinearLayout>
                    <FrameLayout
                        android:id="@+id/videoBlurOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#CC000000"
                        android:visibility="gone"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:id="@+id/videoCenterActionContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="@dimen/item_message_action_padding_h"
                            android:paddingEnd="@dimen/item_message_action_padding_h"
                            android:paddingTop="@dimen/item_message_action_padding_v"
                            android:paddingBottom="@dimen/item_message_action_padding_v"
                            android:background="#80000000">
                            <ImageView
                                android:id="@+id/videoDownloadIcon"
                                android:layout_width="@dimen/item_message_action_icon_size"
                                android:layout_height="@dimen/item_message_action_icon_size"
                                android:src="@drawable/ic_download"
                                android:contentDescription="@null" />
                            <TextView
                                android:id="@+id/videoSizeText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/item_message_inline_gap"
                                android:textSize="@dimen/item_message_secondary_text_size"
                                android:textColor="@android:color/white"
                                android:text="0 KB" />
                        </LinearLayout>

                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/videoCornerActionContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="@dimen/item_message_corner_margin"
                        android:layout_marginBottom="@dimen/item_message_corner_margin"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/item_message_corner_padding_h"
                        android:paddingEnd="@dimen/item_message_corner_padding_h"
                        android:paddingTop="@dimen/item_message_corner_padding_v"
                        android:paddingBottom="@dimen/item_message_corner_padding_v"
                        android:background="#80000000"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ProgressBar
                                android:id="@+id/videoCornerProgress"
                                style="?android:attr/progressBarStyleSmall"
                                android:layout_width="@dimen/item_message_progress_size"
                                android:layout_height="@dimen/item_message_progress_size"
                                android:indeterminate="false"
                                android:max="100"
                                android:progress="0"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/videoCornerActionIcon"
                                android:layout_width="@dimen/item_message_action_icon_size"
                                android:layout_height="@dimen/item_message_action_icon_size"
                                android:layout_gravity="center"
                                android:src="@drawable/export_ic"
                                android:tint="@android:color/white"
                                android:contentDescription="@null" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/videoCornerActionText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/item_message_inline_gap"
                            android:textSize="@dimen/item_message_secondary_text_size"
                            android:textColor="@android:color/white"
                            android:visibility="gone"
                            tools:text="Tekrar dene"
                            tools:visibility="visible" />
                    </LinearLayout>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/imageContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    tools:visibility="visible">
                    <ImageView
                        android:id="@+id/imageThumb"
                        android:layout_width="@dimen/chat_media_max_width"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:minHeight="@dimen/chat_media_min_height"
                        android:maxWidth="@dimen/chat_media_max_width"
                        android:scaleType="centerCrop"
                        android:clipToOutline="true"
                        android:background="@drawable/chat_media_image_bg"
                        tools:src="@android:drawable/ic_menu_gallery" />

                    <LinearLayout
                        android:id="@+id/imageMetaContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="@dimen/item_message_image_meta_margin"
                        android:layout_marginBottom="@dimen/item_message_image_meta_margin"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/item_message_image_meta_padding_h"
                        android:paddingEnd="@dimen/item_message_image_meta_padding_h"
                        android:paddingTop="@dimen/item_message_image_meta_padding_v"
                        android:paddingBottom="@dimen/item_message_image_meta_padding_v"
                        android:background="@null"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/imageTimeView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#CCFFFFFF"
                            tools:text="14:20" />

                        <ImageView
                            android:id="@+id/imageTickView"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            android:scaleType="fitCenter"
                            android:visibility="gone"
                            android:contentDescription="@null"
                            tools:visibility="visible" />
                    </LinearLayout>
                    <FrameLayout
                        android:id="@+id/imageBlurOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#CC000000"
                        android:visibility="gone"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:id="@+id/imageCenterActionContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:background="#80000000">
                            <ImageView
                                android:id="@+id/imageDownloadIcon"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_download"
                                android:contentDescription="@null" />
                            <TextView
                                android:id="@+id/imageSizeText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:textSize="14sp"
                                android:textColor="@android:color/white"
                                android:text="0 KB" />
                        </LinearLayout>

                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/imageCornerActionContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="8dp"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#80000000"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ProgressBar
                                android:id="@+id/imageCornerProgress"
                                style="?android:attr/progressBarStyleSmall"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:indeterminate="false"
                                android:max="100"
                                android:progress="0"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/imageCornerActionIcon"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/export_ic"
                                android:tint="@android:color/white"
                                android:contentDescription="@null" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/imageCornerActionText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textSize="14sp"
                            android:textColor="@android:color/white"
                            android:visibility="gone"
                            tools:text="Tekrar dene"
                            tools:visibility="visible" />
                    </LinearLayout>
                </FrameLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                        android:layout_marginStart="@dimen/item_message_time_row_margin_start"
                android:gravity="end"
                android:layout_gravity="bottom"
                android:layout_marginTop="@dimen/item_message_time_row_margin_top">

                <TextView
                    android:id="@+id/timeView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/item_message_meta_text_size"
                    android:textColor="#CCFFFFFF"
                    tools:text="3:11 pm" />

                <ImageView
                    android:id="@+id/tickView"
                    android:layout_width="@dimen/item_message_tick_size"
                    android:layout_height="@dimen/item_message_tick_size"
                    android:layout_marginStart="@dimen/item_message_time_tick_gap"
                    android:scaleType="fitCenter"
                    android:visibility="gone"
                    android:contentDescription="@null"
                    tools:visibility="visible" />
            </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/captionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/item_message_caption_margin_top"
                android:layout_marginStart="@dimen/item_message_caption_margin_start"
                android:maxWidth="@dimen/chat_bubble_max_width"
                android:gravity="start"
                android:textSize="@dimen/item_message_secondary_text_size"
                android:textColor="@android:color/white"
                android:visibility="gone"
                tools:text="Mesaj altyazısı"
                tools:visibility="visible" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>


