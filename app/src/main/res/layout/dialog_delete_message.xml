<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/hint_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mesaj silinsin mi?"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/deleteForEveryone"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Herkesten sil"
        android:textSize="15sp"
        android:textColor="@android:color/white"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="?attr/selectableItemBackground" />

    <TextView
        android:id="@+id/deleteForMe"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Benden sil"
        android:textSize="15sp"
        android:textColor="@android:color/white"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="?attr/selectableItemBackground" />

    <TextView
        android:id="@+id/deleteCancel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="İptal"
        android:textSize="15sp"
        android:textColor="@android:color/white"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="?attr/selectableItemBackground"
        android:layout_marginTop="8dp" />
</LinearLayout>

