<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="@dimen/map_lesson_item_padding">

    <com.example.app.CircleProgressBar
        android:id="@+id/progressBar"
        android:layout_width="@dimen/map_lesson_outer_ring_size"
        android:layout_height="@dimen/map_lesson_outer_ring_size"
        android:layout_gravity="center"
        app:progress="0"
        app:progressBarThickness="@dimen/map_lesson_progress_thickness"
        app:progressbarColor="@color/lesson_ring_active_blue"
        app:backgroundBarColor="@color/lesson_ring_inactive_dark" />

    <androidx.cardview.widget.CardView
        android:id="@+id/lessonCard"
        android:layout_width="@dimen/map_lesson_card_size"
        android:layout_height="@dimen/map_lesson_card_size"
        android:layout_gravity="center"
        android:foreground="?attr/selectableItemBackground"
        android:stateListAnimator="@animator/lesson_state_animator"
        app:cardCornerRadius="@dimen/map_lesson_card_corner_radius">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/lessonIcon"
                android:layout_width="@dimen/map_lesson_icon_size"
                android:layout_height="@dimen/map_lesson_icon_size"
                android:layout_gravity="center"
                android:src="@drawable/book_icon" />

            <!-- TYPE_CHEST: üç yıldız, ikon alanını eşit bölerek mümkün olan en büyük boyut (fitCenter) -->
            <LinearLayout
                android:id="@+id/chestStarsRow"
                android:layout_width="@dimen/map_lesson_chest_stars_size"
                android:layout_height="@dimen/map_lesson_chest_stars_size"
                android:layout_gravity="center"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/chestStar1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/chestStar2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/chestStar3"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <View
                android:id="@+id/lessonGoldShinePrimary"
                android:layout_width="42dp"
                android:layout_height="10dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="6dp"
                android:layout_marginTop="8dp"
                android:alpha="0"
                android:background="@drawable/lesson_card_shine_primary"
                android:rotation="-24" />

            <View
                android:id="@+id/lessonGoldShineSecondary"
                android:layout_width="24dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="17dp"
                android:layout_marginEnd="8dp"
                android:alpha="0"
                android:background="@drawable/lesson_card_shine_secondary"
                android:rotation="-24" />
        </FrameLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>