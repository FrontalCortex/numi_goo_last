<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bulletinCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/bulletinCardTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Günlük soru"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/bulletinCardChevron"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/bulletinCardSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Bugünün sorusunu çöz ve serini koru."
            android:textSize="14sp"
            android:textColor="#5A5A5A"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/bulletinCardChevron"
            app:layout_constraintTop_toBottomOf="@id/bulletinCardTitle"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/bulletinCardChevron"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Aç"
            android:src="@android:drawable/ic_media_next"
            app:tint="#7A7A7A"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

