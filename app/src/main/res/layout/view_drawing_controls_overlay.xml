<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawingControlsRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal">


    <!-- Soldan kayan asıl panel (dikey düzen) -->
    <LinearLayout
        android:id="@+id/drawingControlsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/message_topbar"
        android:elevation="8dp"
        android:padding="8dp">

        <!-- Satır 1: Kalem + preview -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp">

            <ImageButton
                android:id="@+id/pencilButton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_pencil_circle"
                android:src="@drawable/question_pencil_ic"
                android:contentDescription="Kalem"
                app:tint="@color/message_buttons" />

            <com.example.app.StrokePreviewView
                android:id="@+id/strokePreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Satır 2: Renk şeridi (dikey) -->
        <com.example.app.DrawingColorStripView
            android:id="@+id/colorStrip"
            android:layout_width="24dp"
            android:layout_height="120dp"
            android:layout_marginTop="8dp" />

        <!-- Satır 3: Kalınlık slider'ı (dikey) -->
        <SeekBar
            android:id="@+id/strokeWidthSeekBar"
            android:layout_width="24dp"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="40"
            android:rotation="90" />

        <!-- Satır 4: Undo butonu -->
        <ImageButton
            android:id="@+id/undoButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/undo_drawing_ic"
            android:contentDescription="Geri al"
            app:tint="@color/message_buttons" />

    </LinearLayout>

    <!-- Çekmece butonu: her zaman ekranın kenarında görünen handle -->
    <ImageButton
        android:id="@+id/drawerButton"
        android:layout_width="40dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:background="@color/message_topbar"
        android:contentDescription="Çizim panelini aç/kapat"
        android:rotationY="-180"
        android:src="@drawable/pen_panel_drawer_ic"
        app:tint="@color/message_buttons" />

</LinearLayout>

