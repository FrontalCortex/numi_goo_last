<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/message_topbar"
    tools:context=".BadgeFragment">

    <TextView
        android:id="@+id/badgeTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp"
        android:text="Rozet"
        android:textColor="@android:color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/badgeModeTabs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/badgeTitle"
        app:tabGravity="start"
        app:tabIndicatorColor="@android:color/white"
        app:tabMode="scrollable"
        app:tabSelectedTextColor="@android:color/white"
        app:tabTextColor="#CCFFFFFF" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/badgeAnimContainer"
        android:layout_width="560dp"
        android:layout_height="560dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/badgeModeTabs">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/dailyTasksCompliteBadge"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:lottie_autoPlay="false"
            app:lottie_fileName="daily_tasks_complite_badge.json"
            app:lottie_loop="false" />

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/rocketBadgeAnim"
            android:layout_width="280dp"
            android:layout_height="280dp"
            app:layout_constraintBottom_toBottomOf="@id/dailyTasksCompliteBadge"
            app:layout_constraintEnd_toEndOf="@id/dailyTasksCompliteBadge"
            app:layout_constraintStart_toStartOf="@id/dailyTasksCompliteBadge"
            app:layout_constraintTop_toTopOf="@id/dailyTasksCompliteBadge"
            app:lottie_autoPlay="false"
            app:lottie_fileName="rocket_badge_anim2.json"
            app:lottie_loop="false" />

        <FrameLayout
            android:id="@+id/badgeRewardSlot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="56dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="@id/dailyTasksCompliteBadge"
            app:layout_constraintEnd_toEndOf="@id/dailyTasksCompliteBadge"
            app:layout_constraintStart_toStartOf="@id/dailyTasksCompliteBadge">

            <com.example.app.BalloonPopBurstView
                android:id="@+id/badgeRewardPopBurst"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:clickable="false"
                android:focusable="false"
                android:visibility="invisible" />

            <com.example.app.BadgeRewardTextView
                android:id="@+id/badgeRewardAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.02"
                android:text="50"
                android:textColor="@android:color/white"
                android:textSize="56sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
