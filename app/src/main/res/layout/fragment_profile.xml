<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 1. Üst Alan - Kullanıcı Bilgileri -->
        <androidx.cardview.widget.CardView
            android:id="@+id/profileCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false"
            app:cardBackgroundColor="@color/background_color">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                <!-- Profil Fotoğrafı -->
                <ImageView
                    android:id="@+id/imgProfilePhoto"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="16dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/non_user"
                    android:contentDescription="Profil Fotoğrafı" />

                <!-- Kullanıcı Adı -->
                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kayıt Yapılmadı"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/lesson_completed"
                    android:layout_marginBottom="8dp" />

                <!-- E-posta -->
                <TextView
                    android:id="@+id/tvUserEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:layout_marginBottom="8dp" />

                <!-- Üyelik Durumu -->
                <TextView
                    android:id="@+id/tvMembershipStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/yellow"
                    android:background="@drawable/premium_badge"
                    android:padding="8dp"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:visibility="gone" />

                    <!-- E-posta Doğrulama Uyarısı -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardEmailVerification"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        app:cardBackgroundColor="#FF6B6B"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:cardUseCompatPadding="false">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="⚠️ E-posta adresiniz doğrulanmamış. Lütfen doğrulayın."
                                android:textColor="@color/white"
                                android:textSize="14sp" />

                            <Button
                                android:id="@+id/btnVerifyEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:backgroundTint="#FFFFFF"
                                android:padding="8dp"
                                android:text="Doğrula"
                                android:textColor="#FF6B6B"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnAccountSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Ayarlar"
                    android:padding="8dp"
                    android:src="@drawable/setting_ic"
                    android:tint="@color/white" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- 2. Hesap / Aktivite Bilgileri -->
        <androidx.cardview.widget.CardView
            android:id="@+id/userAdvanceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false"
            app:cardBackgroundColor="@color/background_color">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvUserProgressTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="Kullanıcı İlerlemesi"
                    android:textColor="#93A5B3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCompletedLessons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvSubscriptionInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/profileBadgesCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/background_color"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvProfileBadgesTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Rozetler"
                        android:textColor="#93A5B3"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/btnProfileBadgesArrow"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@null"
                        android:contentDescription="Rozetler"
                        android:padding="5dp"
                        android:src="@drawable/dualingo_arrow_ic"
                        app:tint="#93A5B3" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/badgeItemDart"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="72dp"
                            android:layout_height="72dp">

                            <com.airbnb.lottie.LottieAnimationView
                                android:id="@+id/badgeDartBase"
                                android:layout_width="150dp"
                                android:layout_height="150dp"
                                app:lottie_autoPlay="false"
                                android:layout_gravity="center"
                                app:lottie_loop="false" />

                            <com.airbnb.lottie.LottieAnimationView
                                android:id="@+id/badgeDartTop"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:lottie_autoPlay="false"
                                app:lottie_loop="false" />
                        </FrameLayout>

                        <com.example.app.BadgeRewardTextView
                            android:id="@+id/badgeDartValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="50"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/badgeItemRocket"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="72dp"
                            android:layout_height="72dp">

                            <com.airbnb.lottie.LottieAnimationView
                                android:id="@+id/badgeRocketBase"
                                android:layout_width="150dp"
                                android:layout_height="150dp"
                                android:layout_gravity="center"
                                app:lottie_autoPlay="false"
                                app:lottie_loop="false" />

                            <com.airbnb.lottie.LottieAnimationView
                                android:id="@+id/badgeRocketTop"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:lottie_autoPlay="false"
                                app:lottie_loop="false" />
                        </FrameLayout>

                        <com.example.app.BadgeRewardTextView
                            android:id="@+id/badgeRocketValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="100"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/badgeItemBowling"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="72dp"
                            android:layout_height="72dp">

                            <com.airbnb.lottie.LottieAnimationView
                                android:id="@+id/badgeBowlingBase"
                                android:layout_width="150dp"
                                android:layout_height="150dp"
                                android:layout_gravity="center"
                                app:lottie_autoPlay="false"
                                app:lottie_loop="false" />

                            <com.airbnb.lottie.LottieAnimationView
                                android:id="@+id/badgeBowlingTop"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_badge_circle_frame"
                                app:lottie_autoPlay="false"
                                app:lottie_loop="false" />
                        </FrameLayout>

                        <com.example.app.BadgeRewardTextView
                            android:id="@+id/badgeBowlingValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="150"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/badgeItemGolf"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="72dp"
                            android:layout_height="72dp">

                            <com.airbnb.lottie.LottieAnimationView
                                android:id="@+id/badgeGolfBase"
                                android:layout_width="150dp"
                                android:layout_height="150dp"
                                android:layout_gravity="center"
                                app:lottie_autoPlay="false"
                                app:lottie_loop="false" />

                            <com.airbnb.lottie.LottieAnimationView
                                android:id="@+id/badgeGolfTop"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:lottie_autoPlay="false"
                                app:lottie_loop="false" />
                        </FrameLayout>

                        <com.example.app.BadgeRewardTextView
                            android:id="@+id/badgeGolfValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="225"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
