<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/missionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/missions_quest_title_normal"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="1 ders adımını bitir" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <View
                android:id="@+id/missionProgressTrack"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/mission_progress_track"
                android:contentDescription="@null" />

            <View
                android:id="@+id/missionProgressFill"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_gravity="start|center_vertical"
                android:contentDescription="@null" />

            <View
                android:id="@+id/missionProgressShine"
                android:layout_width="0dp"
                android:layout_height="@dimen/mission_progress_shine_height"
                android:layout_gravity="top|start"
                android:layout_marginStart="@dimen/mission_progress_shine_inset_start"
                android:layout_marginTop="@dimen/mission_progress_shine_top"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/missionProgressText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:elevation="2dp"
                android:gravity="center"
                android:outlineProvider="none"
                android:textColor="@color/button_disabled"
                android:textSize="18sp"
                tools:text="0 / 1" />
        </FrameLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/missionRewardIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="10dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        tools:src="@drawable/cup_ic" />
</LinearLayout>
