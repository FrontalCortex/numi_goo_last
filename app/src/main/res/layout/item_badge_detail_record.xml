<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/recordCard"
    android:layout_width="164dp"
    android:layout_height="260dp"
    android:layout_marginEnd="12dp"
    app:cardBackgroundColor="@color/background_color"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#425563"
    app:strokeWidth="2dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/recordItemContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="10dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <FrameLayout
            android:id="@+id/recordBadgeFrame"
            android:layout_width="120dp"
            android:layout_height="120dp">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/recordBadgeBase"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:lottie_autoPlay="false"
                app:lottie_loop="false" />

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/recordBadgeTop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:lottie_autoPlay="false"
                app:lottie_loop="false" />
        </FrameLayout>

        <com.example.app.BadgeRewardTextView
            android:id="@+id/recordBadgeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-16dp"
            android:text="10"
            android:textColor="@android:color/white"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/recordBadgeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:maxLines="2"
            android:text="Rozet Başlığı"
            android:textColor="#E5EDF2"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/recordBadgeSubtext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:maxLines="1"
            android:text="Varsayılan"
            android:textColor="#6F8595"
            android:textSize="13sp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
